HF_TOKEN="your_hf_token_here"

# Ollama settings
OLLAMA_HOST="http://127.0.0.1:11434"
IMAGE_MODEL="x/flux2-klein"
PLANNER_MODEL="qwen2.5:3b"

# Enforce FLUX runtime probe at startup. Set to 0 only when using a secondary backend.
REQUIRE_FLUX_RUNTIME="1"

# Optional secondary real-image backend (Automatic1111 WebUI API)
# Set SECONDARY_IMAGE_BACKEND to automatic1111 and run with --allow-flux-runtime-fail
# when Ollama FLUX runtime is not available on your platform.
SECONDARY_IMAGE_BACKEND=""
SECONDARY_IMAGE_BACKEND_URL="http://127.0.0.1:7860"